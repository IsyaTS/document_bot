TELEGRAM_BOT_TOKEN=put_new_telegram_token_here

# Optional: OpenAI drafts for letters, offers, claim replies.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: MoySklad API. Do not commit real login/password.
MOYSKLAD_LOGIN=
MOYSKLAD_PASSWORD=

# Local settings
BOT_ADMIN_IDS=
DEFAULT_GROUP_CHAT_ID=
DOCUMENTS_DIR=generated
DATABASE_PATH=data/bot.sqlite3

# Platform runtime settings
# Canonical production runtime target for Hermes is PostgreSQL.
# For local pre-migration recovery you can still point explicitly to SQLite.
POSTGRES_DB=hermes_platform
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me
PLATFORM_DATABASE_URL=postgresql+psycopg://hermes:change-me@127.0.0.1:5433/hermes_platform
PLATFORM_ENV=production
PLATFORM_SECRET_KEY=change-me-now
PLATFORM_CREDENTIALS_KEY=
PLATFORM_DEFAULT_TIMEZONE=Etc/UTC
PLATFORM_INTERNAL_API_TOKEN=change-me-now
PLATFORM_ADMIN_ACCESS_CODE=change-me-now
PLATFORM_API_HOST=0.0.0.0
PLATFORM_API_PORT=8000
PLATFORM_PUBLIC_API_PORT=18000
PLATFORM_WORKER_ID=worker-default
PLATFORM_WORKER_POLL_INTERVAL_SECONDS=30
PLATFORM_RUNTIME_LEASE_TTL_SECONDS=120
